# API Configuration
# ВАЖНО: Скопируйте этот файл в .env и заполните своими ключами

# OmniRoute API endpoint
# Для локальной разработки: http://localhost:20128/v1/chat/completions
# Для продакшена: используйте ngrok или облачный сервер
API_URL=http://localhost:20128/v1/chat/completions

# OmniRoute API Key
API_KEY=your-api-key-here

# Tavily Search API Key (для веб-поиска)
TAVILY_KEY=your-tavily-key-here

# Server Port (для локальной разработки)
PORT=3000
