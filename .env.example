# API Configuration
# ВАЖНО: Скопируйте этот файл в .env и заполните своими ключами

# OmniRoute API endpoint
API_URL=http://localhost:20128/v1/chat/completions

# OmniRoute API Key (получите на omniroute.ai)
API_KEY=your-omniroute-api-key-here

# Tavily Search API Key (получите на tavily.com)
TAVILY_KEY=your-tavily-api-key-here

# Server Port
PORT=3000
